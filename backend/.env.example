# ─── LLM API keys (summarizer fallback chain) ──────────────────────────────
# Order: Groq → Anthropic → OpenAI → Mistral → Together → Gemini → Extractive
# At least ONE is needed for AI summaries; otherwise extractive (3 sentences) is used.

# Groq — fastest + generous free tier (recommended primary)
# Get: https://console.groq.com/keys
GROQ_API_KEY=

# Anthropic Claude — high quality (uses model claude-haiku-4-5-20251001)
# Get: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI — premium fallback
# Get: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Mistral AI — European, solid quality
# Get: https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# Together AI — access to 200+ open-source models
# Get: https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=

# Google Gemini — free tier, last LLM fallback
# Get: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ─── Admin / observability ──────────────────────────────────────────────────
# Admin API key for protected endpoints like POST /pipeline/run
# Leave empty to disable the manual trigger endpoint (it will return 503).
ADMIN_API_KEY=

# ─── App settings ──────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./news.db
TZ=Europe/Bucharest
DAILY_RUN_HOUR=8
